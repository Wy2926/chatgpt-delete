{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "description": "__MSG_appDesc__",
  "default_locale": "en",
  "version": "1.1.0",
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "__MSG_appName__"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["src/i18n.js", "src/icons.js", "src/api.js", "src/queue.js", "src/panel.js", "src/sidebar.js", "src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
